# HMA-Manual local/provider bootstrap.
# The first provider is created only when the manual database has no providers.
MANUAL_BOOTSTRAP_USERNAME=admin
MANUAL_BOOTSTRAP_PASSWORD=change-this-before-public-use
MANUAL_BOOTSTRAP_DISPLAY_NAME=Manual Admin

# For public deployment, set MANUAL_REQUIRE_MFA=1 and provide a TOTP secret
# during provider setup/bootstrap.
MANUAL_REQUIRE_MFA=0
MANUAL_BOOTSTRAP_MFA_SECRET=

# Separate HMA-Manual storage. Keep this separate from DATA_DIR used by HMA.
MANUAL_DATA_DIR=./data/manual

# Local dev public URL. Public deployment should use https://hma-manual.example.com.
MANUAL_PUBLIC_BASE_URL=http://localhost:5182

# Upload and retention controls.
MANUAL_MAX_UPLOAD_MB=150
REVIEW_CAPTURE_RETENTION_DAYS=7
MANUAL_ASSESSMENT_RETENTION_DAYS=365
MANUAL_PROVIDER_SESSION_HOURS=12
MANUAL_UPLOAD_SESSION_DAYS=7
