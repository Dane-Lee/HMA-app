# Access PIN for the app (leave blank to disable — do NOT leave blank in production)
ACCESS_PIN=

# Where assessment data is stored for both local dev and Docker
DATA_DIR=./data

# Maximum video upload size in megabytes (default: 150)
MAX_UPLOAD_MB=150

# Provider pose overlays are derived from MediaPipe landmarks. Set to 0 to disable.
ENABLE_POSE_OVERLAYS=1
MAX_POSE_TRACE_FRAMES=48

# Mobile draft review clips are temporarily retained, then deleted
DRAFT_CAPTURE_RETENTION_DAYS=7

# Structured assessment results are retained, then automatically purged
ASSESSMENT_RETENTION_DAYS=365
